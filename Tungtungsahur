-- Chạy Script B trước
local scriptBLink = "https://raw.githubusercontent.com/ccistao/Ditmemay/refs/heads/main/Cctaone"
loadstring(game:HttpGet(scriptBLink))()

local ScreenGui = Instance.new("ScreenGui")
local XButton = Instance.new("TextButton")
local UIS = game:GetService("UserInputService")

ScreenGui.Name = "KeyXGui"
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = game.CoreGui

XButton.Name = "KeyXButton"
XButton.Parent = ScreenGui
XButton.Size = UDim2.new(0, 60, 0, 60)
XButton.Position = UDim2.new(0, 50, 0, 50)
XButton.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
XButton.BorderSizePixel = 2
XButton.BorderColor3 = Color3.fromRGB(0, 0, 0)
XButton.Text = "X"
XButton.TextScaled = true
XButton.Font = Enum.Font.SourceSansBold
XButton.TextColor3 = Color3.fromRGB(255, 0, 0)
XButton.AutoButtonColor = false

local function onXPressed()
    print("Nút X đã được nhấn!")
end

XButton.MouseButton1Click:Connect(function()
    onXPressed()
end)

UIS.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == Enum.KeyCode.X then
        onXPressed()
    end
end)

local dragging = false
local dragInput, mousePos, framePos

local function update(input)
    local delta = input.Position - mousePos
    XButton.Position = UDim2.new(framePos.X.Scale, framePos.X.Offset + delta.X, framePos.Y.Scale, framePos.Y.Offset + delta.Y)
end

XButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        mousePos = input.Position
        framePos = XButton.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

XButton.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UIS.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        update(input)
    end
end)
