local ESP_ENABLED = false
local ESP_COLOR = Color3.fromRGB(255, 255, 0)
local UPDATE_INTERVAL = 0.5
local eggs = {}

function createBillboard(obj)
    if obj:FindFirstChild("EggESP") then return end
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "EggESP"
    billboard.Adornee = obj
    billboard.Size = UDim2.new(0, 100, 0, 20)
    billboard.AlwaysOnTop = true

    local label = Instance.new("TextLabel", billboard)
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = "EGG"
    label.TextColor3 = ESP_COLOR
    label.TextStrokeTransparency = 0.5
    label.TextScaled = true

    billboard.Parent = obj
    table.insert(eggs, billboard)
end

function clearESP()
    for _, esp in ipairs(eggs) do
        if esp and esp.Parent then
            esp:Destroy()
        end
    end
    eggs = {}
end

function findEggs()
    if not ESP_ENABLED then return end
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name:lower():find("egg") and not obj:FindFirstChild("EggESP") then
            createBillboard(obj)
        end
    end
end

-- GUI
local UIS = game:GetService("UserInputService")

local ScreenGui = Instance.new("ScreenGui", game.CoreGui)
ScreenGui.Name = "EggESP_GUI"
ScreenGui.ResetOnSpawn = false

local Button = Instance.new("TextButton")
Button.Size = UDim2.new(0, 140, 0, 50)
Button.Position = UDim2.new(0, 100, 0, 100)
Button.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
Button.TextColor3 = Color3.new(1, 1, 1)
Button.Font = Enum.Font.SourceSansBold
Button.TextScaled = true
Button.Text = "ESP: OFF"
Button.Parent = ScreenGui

Button.MouseButton1Click:Connect(function()
    ESP_ENABLED = not ESP_ENABLED
    Button.Text = "ESP: " .. (ESP_ENABLED and "ON" or "OFF")
    if not ESP_ENABLED then
        clearESP()
    end
end)

-- Kéo nút (hỗ trợ cảm ứng & chuột)
local dragging = false
local dragStart, startPos

local function updateDrag(input)
    local delta = input.Position - dragStart
    Button.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

Button.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = Button.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        updateDrag(input)
    end
end)

-- Vòng lặp ESP
while true do
    pcall(findEggs)
    wait(UPDATE_INTERVAL)
end
